# ⚠️ 本文件仅作示例，运行时不会读取！请复制为 .env 后填写密钥。
# 也可在项目根目录执行：npm run sync:env（会从主学习 App 同步 server/.env）

DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 语文 AI 登录（管理员账号，任意设备可用同一套凭据）
WENGU_ADMIN_USERNAME=admin
WENGU_ADMIN_PASSWORD=your-strong-password-here

# 可选：会话签名密钥（不填则用管理员密码派生）
# WENGU_SESSION_SECRET=random-long-string

# 可选：成员会话有效期（毫秒，默认 2 小时 = 7200000）
# WENGU_SESSION_TTL_MS=7200000

# 可选：管理员会话有效期（毫秒，默认 7 天 = 604800000）
# WENGU_ADMIN_SESSION_TTL_MS=604800000

# 可选：上游 OpenAI 兼容地址（默认 https://api.deepseek.com）
# DEEPSEEK_API_BASE=https://api.deepseek.com

# 服务监听端口（默认 8790，避免与主学习 App 8787 冲突）
# PORT=8790

# 生产/局域网访问时建议填写允许的前端源，多个用英文逗号分隔
# Cloudflare Pages 示例：
# CORS_ORIGIN=https://quick-math-exercises-app.pages.dev,https://localhost:8790

# 公网 API 根地址（Cloudflare Tunnel 等映射到本机 8790 的 HTTPS 地址）
# 写入构建产物 VITE_WENGU_API_ORIGIN，供 pages.dev 静态页调用登录/AI
# WENGU_PUBLIC_API_URL=https://math-api.example.com
