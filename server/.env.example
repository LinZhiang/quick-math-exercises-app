# ⚠️ 本文件仅作示例。复制为 .env 后填写。

# ========== DeepSeek（默认提供商）==========
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
# DEEPSEEK_API_BASE=https://api.deepseek.com

# ========== 火山方舟 · 豆包 ==========
# DOUBAO_API_KEY=ark-xxxxxxxx（必须是复制出的密钥，以 ark- 开头；不要填 api-key- 名称）
# DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_MODEL_ID=doubao-seed-2-1-pro-260628
# 若已创建推理接入点，也可填 ep-xxxxxxxx（推荐）
# DOUBAO_THINKING=disabled

# 本地 / 局域网登录
WENGU_ADMIN_USERNAME=admin
WENGU_ADMIN_PASSWORD=your-strong-password-here

# 可选
# WENGU_SESSION_SECRET=random-long-string
# WENGU_SESSION_TTL_MS=7200000
# WENGU_ADMIN_SESSION_TTL_MS=604800000
# PORT=8790

# 公网请改用 Cloudflare Pages Secrets（与上列同名），无需隧道、无需 WENGU_PUBLIC_API_URL
# CORS_ORIGIN=https://quick-math-exercises-app.pages.dev
