{
  "name": "quick-math-exercises-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "setup": "node scripts/sync-server-env.mjs && vue-tsc -b && vite build",
    "prebuild": "node scripts/sync-server-env.mjs",
    "predev": "node scripts/sync-server-env.mjs",
    "dev": "vite",
    "dev:ai": "npm --prefix server run dev",
    "dev:full": "concurrently -n web,ai -c blue,green \"npm run dev\" \"npm run dev:ai\"",
    "build": "vue-tsc -b && vite build",
    "sync:env": "node scripts/sync-server-env.mjs",
    "serve:install": "node scripts/family-start.mjs",
    "tunnel:help": "node scripts/tunnel-help.mjs",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "element-plus": "^2.13.7",
    "marked": "^18.0.6",
    "vue": "^3.5.33",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
